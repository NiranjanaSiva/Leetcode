class Solution {
    public boolean hasAlternatingBits(int n) {
        ArrayList<Integer> a=new ArrayList<>();
        int temp=n;
        while(temp>0){
            a.add(temp%2);
            temp=temp/2;
        }
        for(int i=0;i<a.size()-1;i++){
            if(a.get(i)+a.get(i+1)!=1){
                return false;
            }
        }
        return true;
    }
}
