class Solution {
    public boolean isFascinating(int n) {
        int[] arr=new int[10];
        String s=String.valueOf(n);
        s+=String.valueOf(n*2);
        s+=String.valueOf(n*3);
        for(int i=0;i<s.length();i++){
            arr[Integer.parseInt(""+s.charAt(i))]+=1;
        }
        if(arr[0]!=0){
            return false;
        }
        for(int i=1;i<10;i++){
            if(arr[i]!=1){
                return false;
            }
        }
        return true;
    }
}
