class Solution {
    public int distanceTraveled(int mainTank, int additionalTank) {
        int dist=0;
        while(mainTank>=5){
            dist+=5*10;
            mainTank-=5;
            if(additionalTank>=1){
                mainTank+=1;
                additionalTank-=1;
            }
            
        }
        dist+=(mainTank*10);
        return dist;
    }
}
