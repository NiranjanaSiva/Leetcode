class Solution {
    public int minimumChairs(String s) {
        int chairs=0,max=0;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)=='E'){
                chairs++;
                if(chairs>max){
                    max=chairs;
                }
            }
            else{
                chairs--;
            }
        }
        return max;
    }
}
