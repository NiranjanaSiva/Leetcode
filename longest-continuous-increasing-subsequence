class Solution {
    public int findLengthOfLCIS(int[] nums) {
        int c=1,max=-1;
        for(int i=0;i<nums.length-1;i++){
            if(nums[i]<nums[i+1]){
                c++;
            }
            else{
                if(c>max){
                    max=c;
                }
                c=1;
            }
        }
        if(c>max){
            return c;
        }
        return max;
    }
}
