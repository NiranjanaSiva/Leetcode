class Solution {
    public int firstUniqChar(String s) {
        int i,j,flag;
        for(i=0;i<s.length();i++){
            flag=0;
            for(j=0;j<s.length();j++){
                if(i!=j && s.charAt(i)==s.charAt(j)){
                    flag=1;
                    break;
                }
            }
            if(flag==0){
                return i;
            }
        }
        return -1;
    }
}
