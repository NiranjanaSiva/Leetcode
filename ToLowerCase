class Solution {
    public String toLowerCase(String s) {
        String ret="";
        int i;
        for(i=0;i<s.length();i++){
            if(s.charAt(i)>=65 && s.charAt(i)<=90){
                
                ret=ret+(char)(s.charAt(i)+32);
            }
            else{
                ret=ret+s.charAt(i);
            }
        }
        return ret;
    }
}
